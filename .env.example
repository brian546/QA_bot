LLM_PROVIDER=openrouter
EMBEDDING_PROVIDER=

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_ALLOWED_MODELS=google/gemma-4-26b-a4b-it:free:free,openai/gpt-oss-120b:free
OPENROUTER_TIMEOUT=45000
OPENROUTER_MAX_RETRIES=1

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:26b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_ALLOWED_MODELS=gemma4:26b,gpt-oss:20b
OLLAMA_TIMEOUT=45000

LLM_TEMPERATURE=1.0
LLM_DEFAULT_TOP_P=0.2

LLM_MIN_TEMPERATURE=0.0
LLM_MAX_TEMPERATURE=2.0
LLM_MIN_TOP_P=0.0
LLM_MAX_TOP_P=1.0

CITATIONS_MAX_K=10
LEXICAL_WEIGHT=1.0
SEMANTIC_WEIGHT=1.0
MAX_CHUNK_CHARS=1200
CHUNK_OVERLAP=180
MAX_UPLOAD_BYTES=20000000
