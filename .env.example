OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_ALLOWED_MODELS=anthropic/claude-3.5-sonnet,openai/gpt-oss-120b:free
LLM_TEMPERATURE=0.0
LLM_DEFAULT_TOP_P=0.2
LLM_DEFAULT_MAX_TOKENS=1200

LLM_MIN_TEMPERATURE=0.0
LLM_MAX_TEMPERATURE=1.0
LLM_MIN_TOP_P=0.0
LLM_MAX_TOP_P=1.0
LLM_MIN_MAX_TOKENS=64
LLM_HARD_MAX_TOKENS=4096

RETRIEVAL_LEXICAL_K=6
RETRIEVAL_SEMANTIC_K=6
LEXICAL_WEIGHT=1.0
SEMANTIC_WEIGHT=1.0
MAX_CHUNK_CHARS=1200
CHUNK_OVERLAP=180
MAX_UPLOAD_BYTES=20000000
LLM_PROVIDER_NAME=OpenRouter

OPENROUTER_TIMEOUT=45000
OPENROUTER_MAX_RETRIES=1
